# Copy this file to .env and change the secret before deploying for real.
# The app works out of the box without this file, using safe defaults for local/dev use.

# Secret used to sign JWT login tokens. Use a long random string in production.
JWT_SECRET_KEY=please-change-this-secret-in-your-env-file

# How long a login stays valid, in minutes. Default is 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Host port the app is served on (http://localhost:<port>).
FRONTEND_PORT=3000

# Uncomment if `docker compose build` fails with "compose build requires
# buildx 0.17.0 or later" (common on older Unraid/Docker installs). This
# disables Compose's newer "Bake" build path in favor of the classic builder.
# DOCKER_BUILDKIT=0

# Optional: YouTube-koppeling (link projects to real YouTube videos).
# Deze 3 variabelen zijn nu ook per account instelbaar in Instellingen (versleuteld
# opgeslagen) — deze env-vars zijn alleen nog een optionele server-brede terugval.
# Zonder een van beide werkt de rest van de app gewoon door; alleen de
# YouTube-knop bij Instellingen geeft dan een nette foutmelding.
# Zie de "YouTube koppelen" sectie in README.md voor de exacte setup-stappen.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Moet exact overeenkomen met de "Authorized redirect URI" in Google Cloud Console.
# Dev: http://localhost:5173/api/youtube/callback
# Productie: http://<jouw-host>:3000/api/youtube/callback (of je eigen domein)
YOUTUBE_REDIRECT_URI=

# Optional: YouTube trends scanner (§ Trends & Aanbevelingen).
# Ook instelbaar per account in Instellingen (versleuteld opgeslagen) — deze env-var
# is alleen nog een optionele server-brede terugval.
# This is a *separate*, simpler credential than the OAuth vars above: just a plain
# Data API v3 key (Google Cloud Console -> APIs & Services -> Credentials -> Create
# API key), no OAuth consent screen needed. Without it, the Trends tab shows a clear
# "niet geconfigureerd" message instead of crashing.
YOUTUBE_API_KEY=
